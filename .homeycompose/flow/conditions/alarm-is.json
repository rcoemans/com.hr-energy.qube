        { "id": "cooling", "label": { "en": "Cooling", "nl": "Koeling" } },
        { "id": "heating", "label": { "en": "Heating", "nl": "Verwarming" } },
        { "id": "source", "label": { "en": "Source-side", "nl": "Bronzijde" } },
        { "id": "user", "label": { "en": "User-side", "nl": "Gebruikerszijde" } },
        { "id": "legionella_timeout", "label": { "en": "Legionella Timeout", "nl": "Legionella time-out" } },
        { "id": "dhw_timeout", "label": { "en": "DHW Timeout", "nl": "Warmwater time-out" } },
        { "id": "working_hours", "label": { "en": "Working Hours", "nl": "Bedrijfsuren" } },
