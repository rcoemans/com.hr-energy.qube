{
  "title": {
    "en": "Source In Temperature Is ...",
    "nl": "Bron inlaattemperatuur is ..."
  },
  "titleFormatted": {
    "en": "Source In Temperature Is [[operator]] [[value]] °C",
    "nl": "Bron inlaattemperatuur is [[operator]] [[value]] °C"
  },
  "hint": {
    "en": "Checks whether the current source inlet temperature matches the selected condition.",
    "nl": "Controleert of de huidige bron inlaattemperatuur voldoet aan de geselecteerde voorwaarde."
  },
  "args": [
    { "type": "device", "name": "device", "filter": "driver_id=qube" },
    {
      "type": "dropdown", "name": "operator",
      "title": { "en": "Operator", "nl": "Operator" },
      "values": [
        { "id": "gt", "label": { "en": "greater than", "nl": "groter dan" } },
        { "id": "lt", "label": { "en": "less than", "nl": "kleiner dan" } },
        { "id": "gte", "label": { "en": "greater than or equal to", "nl": "groter dan of gelijk aan" } },
        { "id": "lte", "label": { "en": "less than or equal to", "nl": "kleiner dan of gelijk aan" } }
      ]
    },
    { "type": "number", "name": "value", "title": { "en": "Value", "nl": "Waarde" }, "placeholder": { "en": "10" } }
  ]
}
