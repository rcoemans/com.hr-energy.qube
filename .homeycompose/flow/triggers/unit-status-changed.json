{
  "title": {
    "en": "Unit status changed",
    "nl": "Unitstatus gewijzigd"
  },
  "hint": {
    "en": "Triggers when the heat pump unit status changes (e.g. standby → heating). Only fires when the decoded status text changes.",
    "nl": "Wordt geactiveerd wanneer de status van de warmtepomp wijzigt (bijv. stand-by → verwarmen). Wordt alleen geactiveerd als de gedecodeerde statustekst wijzigt."
  },
  "tokens": [
    {
