      "type": "string",
      "title": {
        "en": "Old status",
        "nl": "Oude status"
      },
      "example": {
        "en": "standby"
      }
    },
    {
      "name": "new_status",
      "type": "string",
      "title": {
        "en": "New status",
        "nl": "Nieuwe status"
      },
      "example": {
        "en": "heating"
      }
    },
    {
      "name": "raw_unitstatus",
      "type": "number",
      "title": {
        "en": "Raw unit status",
        "nl": "Ruwe unitstatus"
      },
      "example": {
        "en": "16"
      }
    },
    {
      "name": "status_text",
      "type": "string",
      "title": {
        "en": "Status text",
        "nl": "Statustekst"
      },
      "example": {
        "en": "Heating"
      }
    }
  ],
  "args": [
    {
      "type": "device",
