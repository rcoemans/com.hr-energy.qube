{
  "title": {
    "en": "Set Season Mode",
    "nl": "Seizoensmodus instellen"
  },
  "titleFormatted": {
    "en": "Set Season Mode to [[value]]",
    "nl": "Stel seizoensmodus in op [[value]]"
  },
  "hint": {
    "en": "Switch between heating (winter) and cooling (summer) season. It is also used by LinQ and do not overwrite frequently.",
    "nl": "Schakelen tussen verwarmen (winter) en koelen (zomer). Wordt ook gebruikt door LinQ, schakel niet frequent."
