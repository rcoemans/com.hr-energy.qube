  "args": [
    { "type": "device", "name": "device", "filter": "driver_id=qube" },
    {
      "type": "dropdown", "name": "value",
      "title": { "en": "Season", "nl": "Seizoen" },
      "values": [
        { "id": "0", "label": { "en": "Winter (Heating)", "nl": "Winter (Verwarmen)" } },
        { "id": "1", "label": { "en": "Summer (Cooling)", "nl": "Zomer (Koelen)" } }
      ]
    }
  ]
}
